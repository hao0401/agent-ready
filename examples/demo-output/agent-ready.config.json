{
  "check": {
    "min_score": 80,
    "require_agents": true,
    "baseline": ".agent-ready/baseline.json",
    "ratchet": false
  },
  "ignore_findings": [
    {
      "kind": "prompt-injection",
      "path": "docs/known-safe-example.md",
      "message_contains": "Prompt-injection-like instruction found"
    }
  ],
  "overrides": {
    "commands": {
      "test": [],
      "build": [],
      "lint": [],
      "typecheck": [],
      "run": [],
      "install": []
    },
    "frameworks": [],
    "entry_points": [],
    "important_dirs": [],
    "generated_dirs": [],
    "package_managers": [],
    "monorepo_hints": []
  }
}
